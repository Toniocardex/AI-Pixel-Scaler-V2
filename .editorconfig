root = true

[*]
charset = utf-8

[*.{cs,csx}]
# Codice morto / non usato — severity warning per comparire in build con EnforceCodeStyleInBuild
dotnet_diagnostic.IDE0051.severity = warning   # Private member is unused
dotnet_diagnostic.IDE0052.severity = warning   # Private member can be removed as the value assigned is never read
dotnet_diagnostic.IDE0059.severity = warning   # Unnecessary assignment of a value
dotnet_diagnostic.IDE0060.severity = warning   # Remove unused parameter
dotnet_diagnostic.CA1823.severity = warning   # Avoid unused private fields
dotnet_diagnostic.CA1812.severity = silent    # Avoid uninstantiated internal classes — troppo rumoroso per librerie
