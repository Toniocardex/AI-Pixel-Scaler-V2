<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AiPixelScaler.Desktop.Views.StartPageView"
             Background="#1a1b21">
  <UserControl.Styles>
    <Style Selector="Button.start-card">
      <Setter Property="Background" Value="#10111a"/>
      <Setter Property="BorderBrush" Value="#65758e"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="18,20,18,18"/>
      <Setter Property="Width" Value="392"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.start-card:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#151723"/>
      <Setter Property="BorderBrush" Value="#9ab2d1"/>
    </Style>
    <Style Selector="TextBlock.start-title">
      <Setter Property="Foreground" Value="#c5d7e8"/>
      <Setter Property="FontSize" Value="29"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.start-copy">
      <Setter Property="Foreground" Value="#b9c7d7"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="LineHeight" Value="20"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="Border.start-action">
      <Setter Property="Background" Value="#080a10"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Margin" Value="0,10,0,0"/>
    </Style>
    <Style Selector="Image.card-cover">
      <Setter Property="Stretch" Value="UniformToFill"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="44,*" ClipToBounds="True">
    <Border Grid.Row="0" Background="#5d6f88" CornerRadius="0,0,10,10" Padding="14,0">
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <Border Width="28" Height="28" CornerRadius="6" Background="#2b2947" BorderBrush="#7886a6" BorderThickness="1">
          <Grid RowDefinitions="*,*,*" ColumnDefinitions="*,*,*" Margin="5">
            <Border Grid.Row="0" Grid.Column="0" Background="#5ed4b0" CornerRadius="1"/>
            <Border Grid.Row="0" Grid.Column="2" Background="#8ba7ff" CornerRadius="1"/>
            <Border Grid.Row="1" Grid.Column="1" Background="#df79cf" CornerRadius="1"/>
            <Border Grid.Row="2" Grid.Column="0" Background="#a8e77f" CornerRadius="1"/>
            <Border Grid.Row="2" Grid.Column="2" Background="#67d4ff" CornerRadius="1"/>
          </Grid>
        </Border>
        <TextBlock Text="AI PIXEL SCALER V2" Foreground="#d8e1ec" FontSize="20" FontWeight="SemiBold"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" Background="#202127">
      <Border Background="#101116" Opacity="0.76"/>
      <StackPanel Margin="84,38,84,54" Spacing="30" HorizontalAlignment="Center" MaxWidth="1488">
        <StackPanel Spacing="8">
          <TextBlock Text="BENVENUTO NELLA PIXEL SCALER V2 SUITE"
                     Foreground="#c7d8e9"
                     FontSize="42"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Seleziona lo Studio dedicato per iniziare il tuo flusso di lavoro"
                     Foreground="#bfccda"
                     FontSize="24"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid ColumnDefinitions="392,116,392,116,392" HorizontalAlignment="Center">
          <Button x:Name="BtnStartSprite" Grid.Column="0" Classes="start-card">
            <Grid RowDefinitions="Auto,224,Auto,*,Auto" MinHeight="512">
              <TextBlock Classes="start-title" Text="SPRITE STUDIO"/>
              <Border Grid.Row="1" Width="304" Height="204" CornerRadius="7" ClipToBounds="True" Margin="0,16,0,4" HorizontalAlignment="Center">
                <Image Classes="card-cover" Source="/Assets/Sprite_Studio_Cover.png" Width="374" Height="250"/>
              </Border>
              <TextBlock Grid.Row="2" Text="SPRITE STUDIO" Classes="start-title" FontSize="28"/>
              <StackPanel Grid.Row="3" Spacing="8" Margin="14,10,14,10">
                <TextBlock Classes="start-copy" Text="Modifica e Processing di Frame Statici" HorizontalAlignment="Center"/>
                <TextBlock Classes="start-copy" Text="- Palette Swapping &amp; Forcing&#x0a;- Slicing e Isolamento Contorni&#x0a;- Composizione Floating Paste"/>
              </StackPanel>
              <Border Grid.Row="4" Classes="start-action">
                <TextBlock Text="AVVIA STUDIO" Foreground="#c3cfdf" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              </Border>
            </Grid>
          </Button>

          <Button x:Name="BtnStartAnimation" Grid.Column="2" Classes="start-card">
            <Grid RowDefinitions="Auto,224,Auto,*,Auto" MinHeight="512">
              <TextBlock Classes="start-title" Text="ANIMATION STUDIO"/>
              <Border Grid.Row="1" Width="304" Height="204" CornerRadius="7" ClipToBounds="True" Margin="0,16,0,4" HorizontalAlignment="Center">
                <Image Classes="card-cover" Source="/Assets/Animation_Studio_Cover.png" Width="374" Height="250"/>
              </Border>
              <TextBlock Grid.Row="2" Text="ANIMATION STUDIO" Classes="start-title" FontSize="28"/>
              <StackPanel Grid.Row="3" Spacing="8" Margin="14,10,14,10">
                <TextBlock Classes="start-copy" Text="Riallineamento e Gestione Jittering post-AI" HorizontalAlignment="Center"/>
                <TextBlock Classes="start-copy" Text="- Onion Skinning e Allineamento Pivot&#x0a;- Visual Atlas Builder&#x0a;- Timeline e FPS Controls"/>
              </StackPanel>
              <Border Grid.Row="4" Classes="start-action">
                <TextBlock Text="AVVIA STUDIO" Foreground="#c3cfdf" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              </Border>
            </Grid>
          </Button>

          <Button x:Name="BtnStartTileset" Grid.Column="4" Classes="start-card">
            <Grid RowDefinitions="Auto,224,Auto,*,Auto" MinHeight="512">
              <TextBlock Classes="start-title" Text="TILESET STUDIO"/>
              <Border Grid.Row="1" Width="304" Height="204" CornerRadius="7" ClipToBounds="True" Margin="0,16,0,4" HorizontalAlignment="Center">
                <Image Classes="card-cover" Source="/Assets/Tileset_Studio_Cover.png" Width="374" Height="250"/>
              </Border>
              <TextBlock Grid.Row="2" Text="TILESET STUDIO" Classes="start-title" FontSize="28"/>
              <StackPanel Grid.Row="3" Spacing="8" Margin="14,10,14,10">
                <TextBlock Classes="start-copy" Text="Configurazione Griglie &amp; Pattern Seamless" HorizontalAlignment="Center"/>
                <TextBlock Classes="start-copy" Text="- Configurazione Griglia &amp; Crop-to-Grid&#x0a;- Filtri Seamless (Shift &amp; Dither Blend)&#x0a;- Generatore Procedurale Organico"/>
              </StackPanel>
              <Border Grid.Row="4" Classes="start-action">
                <TextBlock Text="AVVIA STUDIO" Foreground="#c3cfdf" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              </Border>
            </Grid>
          </Button>
        </Grid>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
