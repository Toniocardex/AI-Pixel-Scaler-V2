<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:AiPixelScaler.Desktop.Controls"
        x:Class="AiPixelScaler.Desktop.Views.SandboxWindow"
        Title="Sandbox (Mini-Engine)"
        Icon="/Assets/app.ico"
        Width="800" Height="600"
        Background="#0a0a0c">
  <Grid RowDefinitions="Auto,*" Margin="0">
    <TextBlock Grid.Row="0" Margin="12" Foreground="#aaa" Text="Frecce / WASD — ritorno per chiudere" />
    <ctrl:SandboxView x:Name="View" Grid.Row="1" />
  </Grid>
</Window>
