<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ctrl="using:AiPixelScaler.Desktop.Controls"
        xmlns:vm="using:AiPixelScaler.Desktop.ViewModels"
        xmlns:views="using:AiPixelScaler.Desktop.Views"
        xmlns:studios="using:AiPixelScaler.Desktop.Views.Studios"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="820"
        x:Class="AiPixelScaler.Desktop.Views.MainWindow"
        Title="AI Pixel Studio"
        Icon="/Assets/app.ico"
        WindowState="Maximized"
        Width="1280" Height="820"
        Background="#0d0d10"
        MinWidth="900" MinHeight="600">

  <Window.Styles>

    <!-- ..- TOOLBAR — Lucide-styled tools ............................ -->
    <Style Selector="Path.tool-icon">
      <Setter Property="Width" Value="15"/>
      <Setter Property="Height" Value="15"/>
      <Setter Property="Stroke" Value="#cdcdd9"/>
      <Setter Property="StrokeThickness" Value="1.6"/>
      <Setter Property="StrokeJoin" Value="Round"/>
      <Setter Property="StrokeLineCap" Value="Round"/>
      <Setter Property="Fill" Value="Transparent"/>
      <Setter Property="Stretch" Value="Uniform"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Path.action-icon">
      <Setter Property="Width" Value="14"/>
      <Setter Property="Height" Value="14"/>
      <Setter Property="Stroke" Value="#cdcdd9"/>
      <Setter Property="StrokeThickness" Value="1.6"/>
      <Setter Property="StrokeJoin" Value="Round"/>
      <Setter Property="StrokeLineCap" Value="Round"/>
      <Setter Property="Fill" Value="Transparent"/>
      <Setter Property="Stretch" Value="Uniform"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.workspace-tab-close">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="MinWidth" Value="20"/>
      <Setter Property="MinHeight" Value="20"/>
      <Setter Property="Foreground" Value="#9a9ab0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.workspace-tab-close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#3a3a50"/>
      <Setter Property="Foreground" Value="#f0eeff"/>
    </Style>

    <Style Selector="TabControl.sidebarTabs">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    <Style Selector="TabControl.sidebarTabs TabItem">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#9a9ab0"/>
      <Setter Property="Padding" Value="8,5"/>
    </Style>
    <Style Selector="TabControl.sidebarTabs TabItem /template/ ContentPresenter">
      <Setter Property="Background" Value="#11111a"/>
      <Setter Property="BorderBrush" Value="#222236"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style Selector="TabControl.sidebarTabs TabItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1a1a2a"/>
    </Style>
    <Style Selector="TabControl.sidebarTabs TabItem:selected">
      <Setter Property="Foreground" Value="#f0eeff"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TabControl.sidebarTabs TabItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a2a40"/>
      <Setter Property="BorderBrush" Value="#5c3d9e"/>
    </Style>

  </Window.Styles>

  <Grid>
  <DockPanel x:Name="StudioShell">

    <!-- ..- MENU (File / Moduli) ......................................- -->
    <Menu DockPanel.Dock="Top" Background="#0d0d14" Foreground="#aaa">
      <MenuItem Header="_File">
        <MenuItem x:Name="MenuOpen" Header="Apri immagine…"   InputGesture="Ctrl+O"/>
        <MenuItem x:Name="MenuRevert" Header="Ripristina immagine originale"/>
        <Separator/>
        <MenuItem x:Name="MenuExit" Header="Esci" InputGesture="Alt+F4"/>
      </MenuItem>
      <MenuItem Header="_Modifica">
        <MenuItem x:Name="MenuUndo" Header="Annulla" InputGesture="Ctrl+Z"/>
        <MenuItem x:Name="MenuCopyImage"
                  Header="Copia immagine negli appunti"
                  InputGesture="Ctrl+C"/>
        <MenuItem x:Name="MenuPasteImage"
                  Header="Incolla immagine nel canvas…"
                  InputGesture="Ctrl+V"/>
      </MenuItem>
      <MenuItem Header="_Strumenti">
        <MenuItem x:Name="MenuAnimPreview" Header="Anteprima animazione…" InputGesture="Ctrl+Shift+A"/>
        <MenuItem x:Name="MenuSandbox"     Header="Sandbox fisica in-game…"/>
      </MenuItem>
    </Menu>

    <!-- ..- TOOLBAR (Lucide icons + label) ..............................- -->
    <Border DockPanel.Dock="Top" Background="#11111a" Padding="10,6" BorderThickness="0,0,0,1"
            BorderBrush="#1e1e2e">
      <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">

        <!-- File group -->
        <Button x:Name="BtnOpen" Classes="primary" Padding="11,7"
                ToolTip.Tip="Apri un atlas / sprite sheet">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconFolderOpen}" Classes="tool-icon"
                  Stroke="#f0eeff"/>
            <TextBlock Text="Apri immagine" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button x:Name="BtnRevert" Classes="tool"
                ToolTip.Tip="Ripristina l'atlas all'immagine originale aperta">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconRevert}" Classes="tool-icon"/>
            <TextBlock Text="Ripristina" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button x:Name="BtnUndo" Classes="tool" IsEnabled="False"
                ToolTip.Tip="Annulla l'ultima operazione (Ctrl+Z, max 20 passi)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconUndo}" Classes="tool-icon"/>
            <TextBlock Text="Annulla" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Border Classes="vsep"/>

        <Button x:Name="BtnToolbarRilevaSprite" Classes="tool" MinWidth="104"
                ToolTip.Tip="Rilevamento automatico sprite (CCL): analizza l'immagine e aggiorna celle/lista overlay. Disponibile in ogni tab.">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Data="{StaticResource IconTarget}" Classes="tool-icon"/>
            <TextBlock Text="Rileva sprite" VerticalAlignment="Center" TextWrapping="NoWrap"/>
          </StackPanel>
        </Button>
        <Button Classes="tool"
                ToolTip.Tip="Menu rapido selezione: ROI non distruttiva (trascina, poi aggiusta con maniglie angoli/lati o trascina l’interno per spostare), ritaglio a selezione o rimozione area (Canc).">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Data="{StaticResource IconCrop}" Classes="tool-icon"/>
            <TextBlock Text="Selezione" VerticalAlignment="Center" TextWrapping="NoWrap"/>
          </StackPanel>
          <Button.Flyout>
            <MenuFlyout>
            <MenuItem x:Name="MiToolbarSelectionMode"
                      Header="Seleziona Area"
                      ToolTip.Tip="Disegna un rettangolo sul canvas; dopo il rilascio usa le maniglie azzurre (angoli e lati) per ridimensionare o trascina l’interno per spostare la ROI senza ridisegnarla."/>
            <MenuItem x:Name="MiToolbarCropToSelection"
                      Header="Ritaglia a selezione"/>
            <MenuItem x:Name="MiToolbarRemoveSelectedArea"
                      Header="Rimuovi area selezionata (Canc)"/>
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Border Classes="vsep"/>

        <!-- View tools -->
        <ToggleButton x:Name="ChkWorldGrid" Classes="tool-toggle" IsChecked="True"
                      ToolTip.Tip="Mostra/nascondi la griglia di riferimento sul canvas">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconGrid}" Classes="tool-icon"/>
            <TextBlock Text="Griglia" VerticalAlignment="Center"/>
          </StackPanel>
        </ToggleButton>
        <NumericUpDown x:Name="TxtWorldGridSize" Classes="toolbar"
                       Value="16" Minimum="1" Maximum="512" Increment="8" FormatString="0"
                       Width="56"
                       ToolTip.Tip="Dimensione celle griglia in px (es. 8, 16, 32, 64…)"/>

        <ToggleButton x:Name="ChkSnapGrid" Classes="tool-toggle"
                      ToolTip.Tip="Aggancia ritaglio/selezione al multiplo piů vicino della griglia magnetica">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconMagnet}" Classes="tool-icon"/>
            <TextBlock Text="Magnetica" VerticalAlignment="Center"/>
          </StackPanel>
        </ToggleButton>
        <NumericUpDown x:Name="TxtSnapSize" Classes="toolbar"
                       Value="16" Minimum="1" Maximum="512" Increment="8" FormatString="0"
                       Width="56" IsEnabled="False"
                       ToolTip.Tip="Passo griglia magnetica in px (rotellina del mouse per aumentare/diminuire)"/>
        <Button x:Name="BtnCenterCanvas" Classes="tool"
                ToolTip.Tip="Recentra l'immagine nella viewport mantenendo lo zoom corrente">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconCenter}" Classes="tool-icon"/>
            <TextBlock Text="Centra canvas" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Border Classes="vsep"/>

        <!-- Eraser tool -->
        <ToggleButton x:Name="ChkEraser" Classes="tool-toggle"
                      ToolTip.Tip="Modalitŕ gomma: trascina sull'immagine per cancellare pixel (rendi trasparenti)">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconEraser}" Classes="tool-icon"/>
            <TextBlock Text="Gomma" VerticalAlignment="Center"/>
          </StackPanel>
        </ToggleButton>
        <NumericUpDown x:Name="TxtEraserRadius" Classes="toolbar"
                       Value="4" Minimum="1" Maximum="64" Increment="1" FormatString="0"
                       Width="44" IsEnabled="False"
                       ToolTip.Tip="Dimensione quadrata della gomma in pixel-immagine"/>

        <!-- Pipette tool -->
        <ToggleButton x:Name="ChkPipette" Classes="tool-toggle"
                      ToolTip.Tip="Modalitŕ contagocce: clic sull'immagine per campionare il colore">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconPipette}" Classes="tool-icon"/>
            <TextBlock Text="Contagocce" VerticalAlignment="Center"/>
          </StackPanel>
        </ToggleButton>

      </StackPanel>
    </Border>

    <!-- ..- WORKSPACE TABS (fase 2 MVP) ..................................- -->
    <Border DockPanel.Dock="Top" Background="#101018" Padding="8,6" BorderThickness="0,0,0,1"
            BorderBrush="#1e1e2e">
      <DockPanel LastChildFill="True">
        <TextBlock x:Name="TxtWorkspaceContext" DockPanel.Dock="Left" Margin="0,0,10,0"
                   Foreground="#8a88a8" FontSize="11" VerticalAlignment="Center"
                   Text="Workspace 1 · Pulito"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button x:Name="BtnWorkspaceNewTab" Classes="tool" ToolTip.Tip="Nuovo workspace">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="{StaticResource IconPlus}" Classes="tool-icon"/>
              <TextBlock Text="Nuovo tab" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button x:Name="BtnWorkspaceCloseTab" Classes="tool" ToolTip.Tip="Chiudi il workspace attualmente selezionato">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="{StaticResource IconClose}" Classes="tool-icon"/>
              <TextBlock Text="Chiudi tab" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button x:Name="BtnWorkspaceNewFromClipboard" Classes="tool"
                  ToolTip.Tip="Apre un nuovo tab workspace con l’immagine negli appunti. Per incollare sul canvas del tab corrente usa Modifica ? Incolla o il pulsante nel tab Workspace (Ctrl+V).">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="{StaticResource IconPaste}" Classes="tool-icon"/>
              <TextBlock Text="Nuovo tab da appunti" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <TabControl x:Name="WorkspaceTabs" Classes="sidebarTabs" Margin="0" MinHeight="34" Height="38">
          <TabControl.ItemTemplate>
            <DataTemplate DataType="vm:WorkspaceTabStripItem">
              <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplayTitle}" VerticalAlignment="Center"/>
                <Button Classes="workspace-tab-close"
                        Content="×"
                        Tag="{Binding}"
                        Click="OnWorkspaceTabStripCloseClick"
                        IsVisible="{Binding CloseButtonVisible}"
                        ToolTip.Tip="Chiudi questo workspace"/>
              </StackPanel>
            </DataTemplate>
          </TabControl.ItemTemplate>
          <TabControl.ContentTemplate>
            <DataTemplate DataType="vm:WorkspaceTabStripItem">
              <Border Height="1" IsHitTestVisible="False"/>
            </DataTemplate>
          </TabControl.ContentTemplate>
        </TabControl>
      </DockPanel>
    </Border>

    <!-- ..- WORKFLOW ACTION BAR (task-first CTA) ........................- -->
    <Border DockPanel.Dock="Bottom" Background="#10101a" Padding="10,6"
            BorderThickness="0,1,0,0" BorderBrush="#1e1e2e">
      <Grid ColumnDefinitions="*,Auto,8,Auto">
        <TextBlock x:Name="TxtWorkflowStepSummary"
                   VerticalAlignment="Center"
                   Foreground="#b5b4ca"
                   FontSize="11"
                   Text="Step 1/4 · Importa"/>
        <Button x:Name="BtnWorkflowPrimaryAction" Grid.Column="1" Classes="primary" Content="Step 1 · Importa"/>
        <Button x:Name="BtnWorkflowNextStep" Grid.Column="3" Classes="secondary" Content="Prossimo step"/>
      </Grid>
    </Border>

    <!-- ..- STATUS BAR (in basso) ........................................ -->
    <Border DockPanel.Dock="Bottom" Background="#0a0a10" Padding="10,4"
            BorderThickness="0,1,0,0" BorderBrush="#1e1e2e">
      <Grid ColumnDefinitions="Auto,8,*">
        <TextBlock Grid.Column="0" Text="Stato:" Foreground="#5a5a70" FontSize="11"
                   VerticalAlignment="Center"/>
        <TextBlock Grid.Column="2" x:Name="TxtStatus" Foreground="#5abf5a" FontSize="11"
                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"
                   Text="Pronto. Apri un'immagine per iniziare."/>
      </Grid>
    </Border>

    <!-- ..- CORPO PRINCIPALE ............................................ -->
    <Grid x:Name="MainBodyGrid" ColumnDefinitions="84,*,4,320">

      <!-- ..- LEFT RAIL (workflow task-first) ..........................- -->
      <Border Grid.Column="0" Background="#0c0c14" BorderBrush="#1e1e2e" BorderThickness="0,0,1,0">
        <StackPanel Margin="8,10" Spacing="8">
          <TextBlock Text="Workflow" Foreground="#7f7f98" FontSize="10" HorizontalAlignment="Center"/>
          <StackPanel Spacing="2">
            <ToggleButton x:Name="BtnStepImporta" Classes="tool-toggle" Content="1 · Importa"/>
            <TextBlock x:Name="TxtStepImportaState" Text="? in attesa" Foreground="#7d7d96" FontSize="9" Margin="4,0,0,0"/>
          </StackPanel>
          <StackPanel Spacing="2">
            <ToggleButton x:Name="BtnStepPulisci" Classes="tool-toggle" Content="2 · Pulisci"/>
            <TextBlock x:Name="TxtStepPulisciState" Text="? in attesa" Foreground="#7d7d96" FontSize="9" Margin="4,0,0,0"/>
          </StackPanel>
          <StackPanel Spacing="2">
            <ToggleButton x:Name="BtnStepSliceAllinea" Classes="tool-toggle" Content="3 · Slice"/>
            <TextBlock x:Name="TxtStepSliceState" Text="? in attesa" Foreground="#7d7d96" FontSize="9" Margin="4,0,0,0"/>
          </StackPanel>
          <StackPanel Spacing="2">
            <ToggleButton x:Name="BtnStepEsporta" Classes="tool-toggle" Content="4 · Esporta"/>
            <TextBlock x:Name="TxtStepEsportaState" Text="? in attesa" Foreground="#7d7d96" FontSize="9" Margin="4,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ..- CANVAS + overlay stato vuoto + scroll workspace ............- -->
      <Grid Grid.Column="1" Background="#0a0a0e"
            RowDefinitions="*,Auto" ColumnDefinitions="*,Auto">
        <Grid Grid.Row="0" Grid.Column="0">
          <ctrl:EditorSurface x:Name="Editor" ClipToBounds="True" Zoom="1"
                              RenderOptions.BitmapInterpolationMode="None"/>
          <Border x:Name="EmptyStateDim" ZIndex="8" IsHitTestVisible="False" IsVisible="False"
                  Background="#990a0a12"/>
          <StackPanel x:Name="EmptyStatePanel" ZIndex="10" IsVisible="False"
                      VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" MaxWidth="360">
            <TextBlock x:Name="EmptyStateTitle" Text="Nessun file aperto" Foreground="#b0a8c8"
                       FontSize="16" FontWeight="SemiBold" TextAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmptyStateSub"
                       Text="Clic su «Apri immagine» (toolbar) o sotto. Intanto vedi l'atlas di esempio."
                       Foreground="#5c5a70" FontSize="12" TextAlignment="Center" TextWrapping="Wrap"/>
            <Button x:Name="EmptyStateOpen" Content="Apri un'immagine" Classes="primary"
                    HorizontalAlignment="Center" Margin="0,8,0,0"/>
          </StackPanel>
          <Button x:Name="BtnExpandPanel" ZIndex="20"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,6,6,0" IsVisible="False" Classes="tool" Padding="7,5"
                  ToolTip.Tip="Espandi pannello strumenti">
            <Path Data="{StaticResource IconChevronLeft}" Classes="tool-icon"/>
          </Button>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="Auto,*">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                      Margin="6,0,8,0" Spacing="8">
            <TextBlock Text="Zoom" Foreground="#7f7f98" VerticalAlignment="Center" FontSize="11"/>
            <TextBlock x:Name="TxtWorkspaceZoomPct" Text="100 %" Foreground="#cdcdd9"
                       VerticalAlignment="Center" FontSize="11" MinWidth="44" TextAlignment="Right"/>
            <Slider x:Name="SliderWorkspaceZoom" Width="168" Minimum="0" Maximum="1000"
                    Value="500" VerticalAlignment="Center"
                    ToolTip.Tip="Scala zoom logaritmica verso il 100%: metŕ corsa da 5% a 100%, metŕ da 100% a 6400%. Ancoraggio al centro viewport."/>
          </StackPanel>
          <ScrollBar x:Name="EditorScrollH" Grid.Column="1"
                     Orientation="Horizontal" Height="14" VerticalAlignment="Center"
                     Minimum="0" Maximum="0" Value="0"
                     IsVisible="False"
                     ToolTip.Tip="Sposta il foglio orizzontalmente (pan)"/>
        </Grid>
        <ScrollBar x:Name="EditorScrollV" Grid.Row="0" Grid.Column="1"
                   Orientation="Vertical" Width="14"
                   Minimum="0" Maximum="0" Value="0"
                   IsVisible="False"
                   ToolTip.Tip="Sposta il foglio verticalmente (pan)"/>
        <Border Grid.Row="1" Grid.Column="1" Background="#0a0a0e" Width="14" Height="14"/>
      </Grid>

      <!-- ..- SPLITTER ..................................................- -->
      <GridSplitter x:Name="PanelSplitter" Grid.Column="2" Background="#1a1a26" ResizeDirection="Columns"/>

      <!-- ..- PANNELLO DESTRO ............................................- -->
      <Border Grid.Column="3" Background="#0f0f18" x:Name="RightPanel">
        <DockPanel>

          <!-- Header fisso con titolo + bottone comprimi -->
          <Border DockPanel.Dock="Top" Background="#13131c" Padding="10,5"
                  BorderThickness="0,0,0,1" BorderBrush="#1e1e2e">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Strumenti" Foreground="#888" FontSize="11"
                         FontWeight="Medium" VerticalAlignment="Center"/>
              <Button x:Name="BtnCollapsePanel" Grid.Column="1" Classes="tool" Padding="7,4"
                      ToolTip.Tip="Comprimi pannello (usa il pulsante per espandere)">
                <Path Data="{StaticResource IconChevronRight}" Classes="tool-icon"/>
              </Button>
            </Grid>
          </Border>

          <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="12,10" Spacing="6">

            <!-- CONTAGOCCE hint bar (visibile solo quando attivo) -->
            <Border x:Name="PipetteHintBar" IsVisible="False"
                    Background="#0f1a30" CornerRadius="5" Padding="8,6" Margin="0,0,0,4">
              <StackPanel Spacing="2">
                <TextBlock Foreground="#6090ff" FontSize="10" FontWeight="SemiBold"
                           Text="Contagocce attivo"/>
                <TextBlock x:Name="TxtPipetteHint" Foreground="#6070a0" FontSize="10"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Controlli nascosti necessari al code-behind -->
            <ComboBox x:Name="CmbPipetteTarget" IsVisible="False" SelectedIndex="0">
              <ComboBoxItem Content="Rimuovi sfondo"/>
              <ComboBoxItem Content="Contorno"/>
            </ComboBox>

            <studios:SpriteStudioView x:Name="SpriteStudioPanel" IsVisible="False"/>
            <studios:TilesetStudioView x:Name="TilesetStudioPanel" IsVisible="False"/>

            <Border Background="#0a0a14" BorderBrush="#1e1e2e" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6">
              <StackPanel Spacing="4">
                <TextBlock Classes="fieldLabel" Margin="0,0,0,0" Text="Laboratorio"/>
                <TextBlock Classes="hint" TextWrapping="Wrap"
                           Text="Strumenti secondari di verifica: non influiscono sul flusso principale di slicing/allineamento."/>
                <Grid ColumnDefinitions="*,6,*" Margin="0,4,0,0">
                  <Button x:Name="BtnPanelAnimPreview" Grid.Column="0" Classes="secondary" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Anteprima animazione (cicla i frame del documento corrente)">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconFilm}" Classes="action-icon"/>
                      <TextBlock Text="Animazione" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnPanelSandbox" Grid.Column="2" Classes="secondary" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Sandbox in-game con fisica (movimento, gravitŕ)">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconPlay}" Classes="action-icon"/>
                      <TextBlock Text="Sandbox" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </Grid>
              </StackPanel>
            </Border>

            <TextBlock Text="Studio" Classes="fieldLabel" Margin="0,2,0,0"/>
            <TextBlock Foreground="#5a5a6e" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,2"
                       Text="Tutte le funzioni sono visibili: Sprite, Animation e Tileset raccolgono i comandi esistenti senza tab nascoste."/>
            <Border Background="#0a0a14" BorderBrush="#1e1e2e" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,6,*">
                  <Button Grid.Column="0" x:Name="BtnGoSprite" Content="Sprite Studio" Classes="primary"/>
                  <Button Grid.Column="2" x:Name="BtnGoAllinea" Content="Animation Studio" Classes="secondary"/>
                </Grid>
                <Grid ColumnDefinitions="*,6,*">
                  <Button Grid.Column="0" x:Name="BtnGoTemplate" Content="Tileset Studio" Classes="secondary"/>
                  <Button Grid.Column="2" x:Name="BtnGoStilizza" Content="Stilizza" Classes="secondary"/>
                </Grid>
              </StackPanel>
            </Border>
            <TabControl x:Name="MainTabs" Classes="sidebarTabs" SelectedIndex="0">

            <TabItem Header=" Animation ">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="0" Margin="2,4,2,6">

                <TextBlock Classes="fieldLabel" Text="Allineamento frame"/>
                <TextBlock Classes="hint" TextWrapping="Wrap"
                           Text="Modalitŕ non distruttiva: sposta/allinea i frame e applica solo quando confermi."/>

                <!-- .. ENTRA / ESCI ......................................- -->
                <Button x:Name="BtnAlignEnter"
                        Classes="primary" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                        ToolTip.Tip="Richiede sprite rilevati o griglia divisa">
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <Path Data="{StaticResource IconTarget}" Classes="action-icon"/>
                    <TextBlock Text="Avvia allineamento frame" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Grid ColumnDefinitions="*,8,*" Margin="0,4,0,0" x:Name="AlignActiveBar"
                      IsVisible="False">
                  <Button x:Name="BtnAlignApply" Grid.Column="0"
                          Classes="primary" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Sostituisce l'atlas con la versione allineata">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconCheck}" Classes="action-icon"/>
                      <TextBlock Text="Applica allineamento" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnAlignCancel" Grid.Column="2"
                          Classes="secondary" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Esci senza salvare gli spostamenti">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconX}" Classes="action-icon"/>
                      <TextBlock Text="Annulla" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </Grid>

                <TextBlock Classes="fieldLabel" Text="Azioni rapide"/>
                <CheckBox x:Name="ChkAlignCenterSnapGrid" Margin="0,4,0,2" IsChecked="True"
                          Content="Aggancia angolo opaco a griglia 8 px dopo il centro"
                          ToolTip.Tip="Attivo (consigliato con griglia toolbar multipla di 8): dopo il centro geometrico dell'AABB opaca nella cella, il contenuto puň spostarsi leggermente cosě l'angolo in alto a sinistra dell'area opaca nell'atlas cade su multipli di 8 px. Disattiva per centratura pura senza questo rifinitura. Vale anche per «Centra nelle celle» negli strumenti avanzati."/>
                <Grid ColumnDefinitions="*,6,*" Margin="0,4,0,0">
                  <Button x:Name="BtnAlignAllCenter" Grid.Column="0"
                          Classes="secondary" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Centra l'AABB opaca di ogni frame nel rettangolo della cella. Se «Aggancia angolo opaco…» č attivo sopra, puň applicarsi anche il rifinitura su griglia 8 px (vedi checkbox).">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconCenter}" Classes="action-icon"/>
                      <TextBlock Text="Centra tutti" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnAlignAllBaseline" Grid.Column="2"
                          Classes="secondary" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Centra X + attacca il bottom di ogni sprite al bordo inferiore della cella">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconArrowDown}" Classes="action-icon"/>
                      <TextBlock Text="Piedi (tutti)" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </Grid>
                <Button x:Name="BtnAlignAllReset"
                        Classes="secondary" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                        ToolTip.Tip="Riporta tutti i frame alla posizione originale">
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <Path Data="{StaticResource IconRevert}" Classes="action-icon"/>
                    <TextBlock Text="Ripristina tutti" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Separator Classes="h"/>

                <!-- .. AZIONI SU SELEZIONATO .............................. -->
                <TextBlock Classes="fieldLabel" Text="Frame selezionato"/>
                <TextBlock x:Name="TxtAlignSelected" Classes="hint" Text="Nessuno selezionato"
                           Margin="0,2,0,0"/>
                <Grid ColumnDefinitions="*,6,*" Margin="0,6,0,0">
                  <Button x:Name="BtnAlignSelCenter" Grid.Column="0" Classes="secondary" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Come «Centra tutti», solo sul frame selezionato. Rispetta il checkbox «Aggancia angolo opaco…» nella sezione Azioni rapide.">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconCenter}" Classes="action-icon"/>
                      <TextBlock Text="Centra selezionato" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnAlignSelBaseline" Grid.Column="2" Classes="secondary" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconArrowDown}" Classes="action-icon"/>
                      <TextBlock Text="Piedi (selezionato)" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </Grid>
                <Button x:Name="BtnAlignSelLayoutCenter"
                        Classes="secondary" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                        ToolTip.Tip="Porta il frame selezionato al centro del layout globale (atlas), ignorando il vincolo di cella.">
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <Path Data="{StaticResource IconTarget}" Classes="action-icon"/>
                    <TextBlock Text="Centra nel layout" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button x:Name="BtnAlignSelReset" Classes="secondary" HorizontalAlignment="Stretch" Margin="0,4,0,0">
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <Path Data="{StaticResource IconRevert}" Classes="action-icon"/>
                    <TextBlock Text="Ripristina selezionato" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <TextBlock Classes="hint" Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="Click per selezionare una cella, drag per spostare. Le guide mostrano centro e baseline."/>

                <Separator Classes="h"/>

                <Expander Header="Strumenti avanzati" IsExpanded="False" Margin="0,2,0,0">
                  <StackPanel Spacing="0">
                    <TextBlock Classes="hint" Margin="0,0,0,4"
                               Text="Parametri e operazioni avanzate: estrazione, baseline globale, crop+POT e pivot."/>

                    <TextBlock Classes="fieldLabel" Text="Parametri estrazione"/>
                    <Grid ColumnDefinitions="*,6,80" Margin="0,4,0,0">
                      <TextBlock Grid.Column="0" Text="Padding (px) — cattura overflow:"
                                 Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                      <NumericUpDown x:Name="TxtAlignPadding" Grid.Column="2" Value="0"
                                     Minimum="0" Maximum="128" Increment="2" FormatString="0"
                                     ToolTip.Tip="0 = solo cella stretta. &gt; 0 cattura pixel che traboccano nelle celle adiacenti."/>
                    </Grid>

                    <Separator Classes="h"/>

                    <TextBlock Classes="fieldLabel" Text="Normalizzazione globale (Bottom-Center)"/>
                    <Button x:Name="BtnGlobal" Content="Avvia analisi dimensioni celle"
                            Classes="secondary" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                            ToolTip.Tip="Mostra max / mediana / 90° percentile su W e H di tutte le celle. Avvisa di outlier."/>
                    <TextBlock x:Name="TxtGlobal" Foreground="#555" FontSize="10" Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Text="—  Esegui prima la rilevazione sprite"/>

                    <TextBlock Text="Politica dimensione cella:" Foreground="#666"
                               FontSize="10" Margin="0,8,0,2"/>
                    <ComboBox x:Name="CmbNormalizePolicy" SelectedIndex="0" HorizontalAlignment="Stretch"
                              ToolTip.Tip="Max gonfia se c'č un outlier. Mediana = robusta (clippa outlier). P90 = soft cap (perde solo top-10% px).">
                      <ComboBoxItem Content="Max (classico — puň gonfiare per outlier)"/>
                      <ComboBoxItem Content="Mediana (robusto — clippa outlier)"/>
                      <ComboBoxItem Content="Percentile 90° (soft cap)"/>
                    </ComboBox>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Margin="0,4,0,0"
                               Text="Allinea tutti i frame alla baseline inferiore usando la policy selezionata."/>
                    <Button x:Name="BtnBaselineAlign"
                            Classes="secondary" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                            ToolTip.Tip="Richiede sprite rilevati. Sostituisce l'immagine corrente con la versione normalizzata.">
                      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconArrowDown}" Classes="action-icon"/>
                        <TextBlock Text="Allinea baseline" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <Separator Classes="h"/>

                    <TextBlock Classes="fieldLabel" Text="Crop &amp; POT (asset singolo)"/>
                    <TextBlock Classes="hint" TextWrapping="Wrap"
                               Text="Pipeline fissa: trim AABB su soglia a (o ROI utente) ? padding ? AtlasCropper ? POT (dopo padding, mai a metŕ flusso)."/>

                    <TextBlock Text="Modalitŕ crop:" Foreground="#666" FontSize="10" Margin="0,6,0,2"/>
                    <ComboBox x:Name="CmbCropMode" SelectedIndex="0" HorizontalAlignment="Stretch"
                              ToolTip.Tip="Trim base = AABB stretto · Trim+pad = AABB allargato di N px · ROI = ultima selezione manuale">
                      <ComboBoxItem Content="Trim al contenuto (AABB a)"/>
                      <ComboBoxItem Content="Trim al contenuto + padding"/>
                      <ComboBoxItem Content="ROI utente (ultima selezione)"/>
                    </ComboBox>

                    <Grid ColumnDefinitions="*,6,80" Margin="0,4,0,0">
                      <TextBlock Grid.Column="0" Text="Soglia a (1–255):" Foreground="#666"
                                 FontSize="10" VerticalAlignment="Center"/>
                      <NumericUpDown x:Name="TxtCropAlpha" Grid.Column="2" Value="1" Minimum="1" Maximum="255"
                                     Increment="1" FormatString="0" ShowButtonSpinner="False"
                                     ToolTip.Tip="Pixel con a = soglia sono considerati 'visibili' nell'AABB"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,6,80" Margin="0,4,0,0">
                      <TextBlock Grid.Column="0" Text="Padding (px) — solo Trim+pad:" Foreground="#666"
                                 FontSize="10" VerticalAlignment="Center"/>
                      <NumericUpDown x:Name="TxtCropPadding" Grid.Column="2" Value="4" Minimum="0" Maximum="64"
                                     Increment="1" FormatString="0" ShowButtonSpinner="False"
                                     ToolTip.Tip="Espansione uniforme su 4 lati. Clamp ai bordi atlas."/>
                    </Grid>

                    <TextBlock Text="Politica POT:" Foreground="#666" FontSize="10" Margin="0,6,0,2"/>
                    <ComboBox x:Name="CmbCropPot" SelectedIndex="0" HorizontalAlignment="Stretch"
                              ToolTip.Tip="POT applicata DOPO il padding. Esempio: 192×100 ? PerAxis=256×128, Square=256×256.">
                      <ComboBoxItem Content="Nessuna (dimensioni naturali)"/>
                      <ComboBoxItem Content="Per asse — W'=Np2(W), H'=Np2(H)"/>
                      <ComboBoxItem Content="Quadrata — side=Np2(max(W,H))"/>
                    </ComboBox>

                    <Button x:Name="BtnApplyCropPot"
                            Classes="primary" HorizontalAlignment="Stretch" Margin="0,6,0,0"
                            ToolTip.Tip="Sostituisce l'immagine con la versione croppata + POT. Annullabile (Ctrl+Z).">
                      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconScissors}" Classes="action-icon"/>
                        <TextBlock Text="Applica ritaglio + POT" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <Button x:Name="BtnCenterInCells"
                            Classes="secondary" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                            ToolTip.Tip="Centra il contenuto opaco in ogni cella dell’atlas corrente (senza workbench). La rifinitura su griglia 8 px segue l’opzione «Aggancia angolo opaco a griglia 8 px dopo il centro» nella sezione Azioni rapide sopra (tab Allinea); se disattivata, solo centro geometrico.">
                      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconCenter}" Classes="action-icon"/>
                        <TextBlock Text="Centra nelle celle" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                    <Button x:Name="BtnSnapCellsToGrid"
                            Classes="secondary" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                            ToolTip.Tip="Sposta ogni sprite cosě che l’angolo in alto a sinistra della cella sia su multipli del passo «Griglia» in toolbar (origine 0,0 atlas). Dimensioni cella invariate. Se due celle finiscono sovrapposte, vince il disegno successivo nell’ordine della lista.">
                      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconGrid}" Classes="action-icon"/>
                        <TextBlock Text="Aggancia alla griglia (toolbar)" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <Separator Classes="h"/>

                    <TextBlock Classes="fieldLabel" Text="Punto di ancoraggio (per engine / export JSON)"/>
                    <TextBlock Classes="hint"
                               Text="0 = bordo sinistro/alto  ·  0.5 = centro  ·  1 = bordo destro/basso"/>

                    <Grid ColumnDefinitions="72,*,42" Margin="0,8,0,0">
                      <TextBlock Grid.Column="0" Text="Orizzontale" Foreground="#666" FontSize="10"
                                 VerticalAlignment="Center"/>
                      <Slider x:Name="SliderPivotX" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"/>
                      <TextBlock x:Name="LblPivotX" Grid.Column="2" Foreground="#888" FontSize="11"
                                 Text="0.50" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="72,*,42" Margin="0,4,0,0">
                      <TextBlock Grid.Column="0" Text="Verticale" Foreground="#666" FontSize="10"
                                 VerticalAlignment="Center"/>
                      <Slider x:Name="SliderPivotY" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"/>
                      <TextBlock x:Name="LblPivotY" Grid.Column="2" Foreground="#888" FontSize="11"
                                 Text="0.50" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                  </StackPanel>
                </Expander>

              </StackPanel>
              </ScrollViewer>
            </TabItem>
            <TabItem Header=" Export ">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="6" Margin="2,4,2,6">

                <Grid ColumnDefinitions="*,8,*">
                  <Button x:Name="BtnExportPng" Grid.Column="0" HorizontalAlignment="Stretch"
                          Classes="primary"
                          ToolTip.Tip="Esporta tutti gli sprite in un unico file PNG">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconImage}" Classes="action-icon"/>
                      <TextBlock Text="Esporta atlas PNG" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnExportJson" Grid.Column="2" HorizontalAlignment="Stretch"
                          Classes="secondary" Content="{}&#123;&#125;  Esporta JSON"
                          ToolTip.Tip="Esporta le coordinate e i pivot degli sprite in formato JSON"/>
                </Grid>
                <CheckBox x:Name="ChkExportAtlasIndexedPng" Content="Atlas PNG a palette 8-bit (file piů compatto)"
                          ToolTip.Tip="Salva come PNG indicizzato (PLTE); quantizzazione Wu automatica se non hai giŕ ridotto la palette."/>
                <CheckBox x:Name="ChkExportKeepCellSize" Content="Mantieni dimensione cella (atlas non compatto)"
                          ToolTip.Tip="Ogni frame occupa una cella uniforme W×H (presa dalle celle correnti) invece del pack compatto tight. Utile per animazioni con frame fissi."/>
                <CheckBox x:Name="ChkExportCustomCellSize" Content="Uniforme personalizzato (W×H)"
                          ToolTip.Tip="Usa una dimensione cella fissa scelta manualmente per tutti i frame. Se troppo piccola rispetto ai frame reali, l'export viene bloccato."/>
                <Grid ColumnDefinitions="*,8,80,8,80" Margin="0,2,0,0">
                  <TextBlock Grid.Column="0" Text="Cella custom (W×H):" Foreground="#666"
                             FontSize="10" VerticalAlignment="Center"/>
                  <TextBox x:Name="TxtExportCellW" Grid.Column="2" Text="208" IsEnabled="False"/>
                  <TextBox x:Name="TxtExportCellH" Grid.Column="4" Text="256" IsEnabled="False"/>
                </Grid>
                <TextBlock x:Name="TxtExportCellMinRequired" Classes="hint" Margin="0,2,0,0"
                           Text="Min richiesto: -"/>
                <Grid ColumnDefinitions="*,8,*">
                  <Button x:Name="BtnExportFramesZip" Grid.Column="0" HorizontalAlignment="Stretch"
                          Classes="secondary"
                          ToolTip.Tip="Esporta ogni sprite come file PNG separato in un archivio ZIP">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconArchive}" Classes="action-icon"/>
                      <TextBlock Text="Esporta ZIP frame" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnExportTiled" Grid.Column="2" HorizontalAlignment="Stretch"
                          Classes="secondary"
                          ToolTip.Tip="Esporta una mappa compatibile con Tiled Map Editor">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                      <Path Data="{StaticResource IconMap}" Classes="action-icon"/>
                      <TextBlock Text="Esporta Tiled" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </Grid>

                <TextBlock Classes="hint" Margin="0,2,0,0"
                           Text="Se non hai diviso in sprite, viene esportata l'intera immagine."/>
              </StackPanel>
              </ScrollViewer>
            </TabItem>

            <!-- .......................................................... -->
            <!-- TAB: Selezione libera                                    -->
            <!-- Area di lavoro semplice: seleziona ? esporta o ritaglia -->
            <!-- .......................................................... -->
            <TabItem Header=" Guida ">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="0" Margin="2,4,2,6">
                <TextBlock Classes="fieldLabel" Text="Mini guida allineamento animazioni"/>
                <TextBlock Classes="hint" TextWrapping="Wrap"
                           Text="Regole rapide per scegliere subito il comando giusto in base al tipo di animazione."/>

                <Separator Classes="h"/>
                <TextBlock Classes="fieldLabel" Text="Scelta veloce per tipo animazione"/>
                <Border Background="#0a0a14" BorderBrush="#1e1e2e" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="• Idle: usa Piedi (tutti) per tenere stabile il contatto a terra."/>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="• Run/Walk: prima Piedi (tutti), poi piccoli ritocchi solo sui frame che saltano."/>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="• Attack/Cast: parti con Centra tutti, poi correggi i keyframe forti con Centra selezionato."/>
                  </StackPanel>
                </Border>

                <Separator Classes="h"/>
                <TextBlock Classes="fieldLabel" Text="Quando usare Centra nel layout"/>
                <Border Background="#0a0a14" BorderBrush="#1e1e2e" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="• Debug rapido di un frame singolo fuori asse."/>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="• Confronto silhouette/proporzioni al centro dell'atlas."/>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="• Non usarlo come default per tutta l'animazione: per coerenza gameplay preferisci la baseline."/>
                  </StackPanel>
                </Border>

                <Separator Classes="h"/>
                <TextBlock Classes="fieldLabel" Text="Checklist prima export"/>
                <Border Background="#0a0a14" BorderBrush="#1e1e2e" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="1) Rileva sprite (toolbar) oppure Dividi a griglia."/>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="2) Avvia allineamento frame."/>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="3) Applica allineamento."/>
                    <TextBlock Classes="hint" TextWrapping="Wrap" Text="4) Controlla preview animazione e solo dopo esporta PNG/JSON."/>
                  </StackPanel>
                </Border>
              </StackPanel>
              </ScrollViewer>
            </TabItem>

            </TabControl>

          </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Grid>
  </DockPanel>
  <views:StartPageView x:Name="StartPage" ZIndex="100"/>
  </Grid>
</Window>

