<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:studios="clr-namespace:AiPixelScaler.Desktop.Views.Studios"
             x:Class="AiPixelScaler.Desktop.Views.Studios.TilesetStudioView">
  <UserControl.Styles>
    <Style Selector="TextBlock.studio-title">
      <Setter Property="Foreground" Value="#d8e6ff"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBlock.studio-hint">
      <Setter Property="Foreground" Value="#7e86a8"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="Foreground" Value="#f1f4ff"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Border.studio-section">
      <Setter Property="Background" Value="#0a0c14"/>
      <Setter Property="BorderBrush" Value="#23283a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="9"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
  </UserControl.Styles>

  <StackPanel Spacing="0">

    <!-- Header -->
    <Border Background="#111827" BorderBrush="#2d3652" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
      <StackPanel Spacing="4">
        <TextBlock Classes="studio-title" Text="Tileset Studio"/>
        <TextBlock Classes="studio-hint"
                   Text="Griglie, palette, seamless, template e export Tiled."/>
      </StackPanel>
    </Border>

    <!-- 1. Flusso -->
    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Flusso di lavoro"/>
        <Button x:Name="BtnTilesetOpen" Classes="primary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconFolderOpen}" Classes="action-icon"/>
            <TextBlock Text="Apri immagine"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- 2. Palette -->
    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Palette"/>
        <TextBlock Classes="studio-hint"
                   Text="Riduce la palette con Wu oppure applica una palette retro fissa."/>
        <Grid ColumnDefinitions="*,6,*">
          <TextBlock Grid.Column="0" Classes="studio-hint" Text="Palette:" VerticalAlignment="Center"/>
          <ComboBox x:Name="CmbTilesetPalettePreset" Grid.Column="2" SelectedIndex="0" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="Auto AI (Wu)"/>
            <ComboBoxItem Content="Game Boy DMG"/>
            <ComboBoxItem Content="PICO-8 (16)"/>
            <ComboBoxItem Content="NES (16)"/>
            <ComboBoxItem Content="Sweetie 16"/>
            <ComboBoxItem Content="CGA (4)"/>
          </ComboBox>
        </Grid>
        <Grid ColumnDefinitions="*,6,64">
          <TextBlock Grid.Column="0" Classes="studio-hint" Text="Colori (Auto AI):" VerticalAlignment="Center"/>
          <TextBox x:Name="TxtTilesetPaletteColors" Grid.Column="2" Text="16"/>
        </Grid>
        <CheckBox x:Name="ChkTilesetDither" Content="Floyd-Steinberg dither"
                  ToolTip.Tip="Distribuisce l'errore di quantizzazione sui pixel vicini"/>
        <Button x:Name="BtnTilesetApplyPalette" Classes="secondary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconWand}" Classes="action-icon"/>
            <TextBlock Text="Applica palette"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- 3. Seamless e Tile -->
    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Seamless e Tile"/>
        <TextBlock Classes="studio-hint"
                   Text="Sposta (W/2, H/2) e dithera il seam con Bayer 4x4 deterministico. Pixel art preservata."/>
        <Grid ColumnDefinitions="*,6,64">
          <TextBlock Grid.Column="0" Classes="studio-hint" Text="Larghezza dither (px):" VerticalAlignment="Center"/>
          <TextBox x:Name="TxtTilesetBlend" Grid.Column="2" Text="4"
                   ToolTip.Tip="Banda di transizione attorno al seam (1-16 px)"/>
        </Grid>
        <Button x:Name="BtnTilesetMakeTileable" Classes="secondary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconScissors}" Classes="action-icon"/>
            <TextBlock Text="Rendi tile ripetibile"/>
          </StackPanel>
        </Button>
        <CheckBox x:Name="ChkTilesetTilePreview" Content="Anteprima tile 3x3 sul canvas"
                  ToolTip.Tip="Mostra il tile ripetuto 9 volte per evidenziare le cuciture"/>
      </StackPanel>
    </Border>

    <!-- 4. Allineamento dimensioni -->
    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Allineamento dimensioni"/>
        <TextBlock Classes="studio-hint"
                   Text="Aggiunge bordo trasparente per portare le dimensioni a un multiplo di N px."/>
        <Grid ColumnDefinitions="*,6,64">
          <TextBlock Grid.Column="0" Classes="studio-hint" Text="Multiplo (px):" VerticalAlignment="Center"/>
          <TextBox x:Name="TxtTilesetPadMultiple" Grid.Column="2" Text="16"/>
        </Grid>
        <Button x:Name="BtnTilesetPadToMultiple" Classes="secondary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconGrid}" Classes="action-icon"/>
            <TextBlock Text="Allinea dimensioni"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- 5. Griglia condivisa -->
    <studios:GridSectionView x:Name="GridPanel"/>

    <!-- 6. Export e strumenti avanzati -->
    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Export"/>
        <Button x:Name="BtnTilesetExportTiled" Classes="secondary" HorizontalAlignment="Stretch"
                ToolTip.Tip="Esporta una mappa compatibile con Tiled Map Editor">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconMap}" Classes="action-icon"/>
            <TextBlock Text="Esporta Tiled JSON"/>
          </StackPanel>
        </Button>

        <Expander Header="Strumenti avanzati" IsExpanded="False" Margin="0,4,0,0">
          <StackPanel Spacing="6" Margin="0,4,0,0">
            <TextBlock Classes="section-title" Text="Crop &amp; POT (asset singolo)"/>
            <TextBlock Classes="studio-hint"
                       Text="Pipeline: trim AABB → padding → POT. Annullabile con Ctrl+Z."/>

            <TextBlock Classes="studio-hint" Text="Modalità crop:" Margin="0,4,0,0"/>
            <ComboBox x:Name="CmbTilesetCropMode" SelectedIndex="0" HorizontalAlignment="Stretch">
              <ComboBoxItem Content="Trim al contenuto (AABB α)"/>
              <ComboBoxItem Content="Trim + padding"/>
              <ComboBoxItem Content="ROI utente (ultima selezione)"/>
            </ComboBox>

            <Grid ColumnDefinitions="*,6,64" Margin="0,4,0,0">
              <TextBlock Grid.Column="0" Classes="studio-hint" Text="Soglia α (1-255):" VerticalAlignment="Center"/>
              <TextBox x:Name="TxtTilesetCropAlpha" Grid.Column="2" Text="1"/>
            </Grid>
            <Grid ColumnDefinitions="*,6,64">
              <TextBlock Grid.Column="0" Classes="studio-hint" Text="Padding (px):" VerticalAlignment="Center"/>
              <TextBox x:Name="TxtTilesetCropPadding" Grid.Column="2" Text="4"/>
            </Grid>

            <TextBlock Classes="studio-hint" Text="Politica POT:" Margin="0,4,0,0"/>
            <ComboBox x:Name="CmbTilesetCropPot" SelectedIndex="0" HorizontalAlignment="Stretch">
              <ComboBoxItem Content="Nessuna"/>
              <ComboBoxItem Content="Per asse — W=N²(W), H=N²(H)"/>
              <ComboBoxItem Content="Quadrata — side=N²(max(W,H))"/>
            </ComboBox>

            <Button x:Name="BtnTilesetApplyCropPot" Classes="primary" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                    ToolTip.Tip="Applica ritaglio + POT. Annullabile (Ctrl+Z).">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Path Data="{StaticResource IconScissors}" Classes="action-icon"/>
                <TextBlock Text="Applica ritaglio + POT"/>
              </StackPanel>
            </Button>

            <Separator Margin="0,4"/>

            <TextBlock Classes="section-title" Text="Aggancia celle alla griglia"/>
            <TextBlock Classes="studio-hint"
                       Text="Sposta ogni sprite così che l'angolo top-left della cella sia su multipli del passo griglia (toolbar). Richiede sprite rilevati."/>
            <Button x:Name="BtnTilesetSnapCells" Classes="secondary" HorizontalAlignment="Stretch"
                    ToolTip.Tip="Aggancia celle alla griglia di riferimento (passo dalla toolbar)">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Path Data="{StaticResource IconGrid}" Classes="action-icon"/>
                <TextBlock Text="Aggancia alla griglia"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Expander>
      </StackPanel>
    </Border>

  </StackPanel>
</UserControl>
