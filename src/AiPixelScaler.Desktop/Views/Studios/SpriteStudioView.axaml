<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AiPixelScaler.Desktop.Views.Studios.SpriteStudioView">
  <UserControl.Styles>
    <Style Selector="TextBlock.studio-title">
      <Setter Property="Foreground" Value="#d8e6ff"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBlock.studio-hint">
      <Setter Property="Foreground" Value="#7e86a8"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="Foreground" Value="#f1f4ff"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Border.studio-section">
      <Setter Property="Background" Value="#0a0c14"/>
      <Setter Property="BorderBrush" Value="#23283a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="9"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
  </UserControl.Styles>

  <StackPanel Spacing="0">
    <Border Background="#111827" BorderBrush="#2d3652" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
      <StackPanel Spacing="4">
        <TextBlock Classes="studio-title" Text="Sprite Studio"/>
        <TextBlock Classes="studio-hint"
                   Text="Gestione frame statico: import, pulizia, ROI, slicing, palette e export sprite."/>
      </StackPanel>
    </Border>

    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Flusso di lavoro"/>
        <Button x:Name="BtnSpriteOpen" Classes="primary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconFolderOpen}" Classes="action-icon"/>
            <TextBlock Text="Apri immagine"/>
          </StackPanel>
        </Button>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteDefault" Grid.Column="0" Classes="secondary" Content="Default"/>
          <Button x:Name="BtnSpriteCleanup" Grid.Column="2" Classes="secondary" Content="Cleanup"/>
        </Grid>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteSafe" Grid.Column="0" Classes="secondary" Content="Sicuro"/>
          <Button x:Name="BtnSpriteAggressive" Grid.Column="2" Classes="secondary" Content="Aggressivo"/>
        </Grid>
        <Button x:Name="BtnSpriteOneClick" Classes="secondary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconWand}" Classes="action-icon"/>
            <TextBlock Text="One-click cleanup"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Classes="section-title" Text="Filtri Sprite"/>
          <Border x:Name="PresetBadgeBorder" Grid.Column="1"
                  Background="#1e2a1e" BorderBrush="#2d4a2d" BorderThickness="1"
                  CornerRadius="3" Padding="5,2" IsVisible="False">
            <TextBlock x:Name="TxtPresetBadge" FontSize="10" Foreground="#7ab87a" Text="Default"/>
          </Border>
        </Grid>
        <TextBlock Classes="studio-hint" Text="Preset, cleanup e filtri dettagliati agiscono sugli stessi parametri della pipeline."/>

        <Border Background="#090b12" BorderBrush="#1d2333" BorderThickness="1" CornerRadius="4" Padding="7">
          <StackPanel Spacing="5">
            <TextBlock Classes="section-title" Text="Rimozione sfondo"/>
            <TextBlock Classes="studio-hint" Text="Flood fill dal bordo: rimuove lo sfondo connesso all'esterno senza toccare l'interno. Usa ◉ per campionare il colore (5×5 px)."/>
            <Grid ColumnDefinitions="Auto,4,*,6,22,6,64">
              <TextBlock Grid.Column="0" Classes="studio-hint" VerticalAlignment="Center" Text="Colore"/>
              <TextBox x:Name="TxtSpriteBackgroundHex" Grid.Column="2" Text="#00FF00" PlaceholderText="#RRGGBB"/>
              <Button x:Name="BtnSpriteBgPipette" Grid.Column="4" Width="22" Height="22" Padding="0"
                      Content="◉" FontSize="11"
                      ToolTip.Tip="Campiona colore sfondo dall'immagine (area 5×5 px, auto-disattiva dopo il pick). Poi premi 'Rimuovi sfondo'."/>
              <TextBox x:Name="TxtSpriteBackgroundTol" Grid.Column="6" Text="10"
                       ToolTip.Tip="Tolleranza colore [0-255]. Aumenta se lo sfondo non è completamente uniforme (es. JPEG: 15-30)."/>
            </Grid>
            <Grid ColumnDefinitions="*,6,64">
              <TextBlock Grid.Column="0" Classes="studio-hint" Text="Protezione bordi (Sobel)"
                         ToolTip.Tip="Soglia Sobel [0-500]. Valori più bassi = protezione meno aggressiva. 0 = disabilitata. Default 100 ignora artefatti JPEG ma blocca bordi sprite."/>
              <TextBox x:Name="TxtSpriteBackgroundEdge" Grid.Column="2" Text="100"
                       ToolTip.Tip="100 = default. Prova 50 o 0 se il flood si blocca su sfondo uniforme."/>
            </Grid>
            <CheckBox x:Name="ChkSpriteAlphaThreshold" Content="Binarizza alpha dopo rimozione"
                      ToolTip.Tip="Azzera i pixel semi-trasparenti residui (alpha &lt; soglia) dopo il flood fill. Utile per immagini già con canale alpha parziale."/>
            <TextBox x:Name="TxtSpriteAlphaThreshold" Text="128"
                     ToolTip.Tip="Soglia alpha [1-254]. Pixel con alpha &lt; soglia → trasparenti; alpha ≥ soglia → opachi."/>
            <Button x:Name="BtnSpriteBackgroundIsolation" Classes="secondary" Content="Rimuovi sfondo" HorizontalAlignment="Stretch"/>
          </StackPanel>
        </Border>

        <Border Background="#090b12" BorderBrush="#1d2333" BorderThickness="1" CornerRadius="4" Padding="7">
          <StackPanel Spacing="5">
            <TextBlock Classes="section-title" Text="Edge Refinement"/>
            <Grid ColumnDefinitions="*,6,64">
              <TextBlock Grid.Column="0" Classes="studio-hint" Text="Soglia opaco"/>
              <TextBox x:Name="TxtSpriteDefringeOpaque" Grid.Column="2" Text="250"/>
            </Grid>
            <Button x:Name="BtnSpriteDefringe" Classes="secondary" Content="Applica defringe" HorizontalAlignment="Stretch"/>
            <CheckBox x:Name="ChkSpriteOutline" Content="Contorno 1px"/>
            <TextBox x:Name="TxtSpriteOutlineHex" Text="#000000"/>
          </StackPanel>
        </Border>

        <Border Background="#090b12" BorderBrush="#1d2333" BorderThickness="1" CornerRadius="4" Padding="7">
          <StackPanel Spacing="5">
            <TextBlock Classes="section-title" Text="Denoise"/>
            <Grid ColumnDefinitions="*,6,64">
              <TextBlock Grid.Column="0" Classes="studio-hint" Text="Isole minime"/>
              <TextBox x:Name="TxtSpriteMinIsland" Grid.Column="2" Text="2"/>
            </Grid>
            <CheckBox x:Name="ChkSpriteMajorityDenoise" Content="Maggioranza 3x3"/>
            <Grid ColumnDefinitions="*,6,*">
              <Button x:Name="BtnSpriteMedian" Grid.Column="0" Classes="secondary" Content="Median"/>
              <Button x:Name="BtnSpriteDenoise" Grid.Column="2" Classes="secondary" Content="Isole"/>
            </Grid>
          </StackPanel>
        </Border>

        <Border Background="#090b12" BorderBrush="#1d2333" BorderThickness="1" CornerRadius="4" Padding="7">
          <StackPanel Spacing="5">
            <TextBlock Classes="section-title" Text="Quantize"/>
            <TextBlock Classes="studio-hint"
                       Text="⚠ Applica prima della rimozione sfondo: rimappa tutti i pixel alla palette ridotta e aggiorna automaticamente il colore chiave."
                       TextWrapping="Wrap"/>
            <CheckBox x:Name="ChkSpriteQuantize" Content="Abilita Quantize"/>
            <Grid ColumnDefinitions="*,6,74">
              <TextBlock Grid.Column="0" Classes="studio-hint" Text="Colori max"/>
              <TextBox x:Name="TxtSpriteQuantizeColors" Grid.Column="2" Text="16"/>
            </Grid>
            <ComboBox x:Name="CmbSpriteQuantizeMethod" SelectedIndex="0" HorizontalAlignment="Stretch">
              <ComboBoxItem Content="Wu (ImageSharp)"/>
              <ComboBoxItem Content="Octree"/>
            </ComboBox>
            <Grid ColumnDefinitions="*,6,*">
              <Button x:Name="BtnSpriteQuantizeApply" Grid.Column="0" Classes="secondary"
                      Content="Applica" HorizontalAlignment="Stretch"
                      ToolTip.Tip="Applica la quantizzazione e aggiorna il colore sfondo alla voce più vicina nella palette."/>
              <Button x:Name="BtnSpriteAnalyzePalette" Grid.Column="2" Classes="secondary"
                      Content="Analizza" HorizontalAlignment="Stretch"
                      ToolTip.Tip="Mostra i colori presenti nell'immagine senza modificarla. Clicca uno swatch per impostarlo come colore sfondo."/>
            </Grid>
            <TextBlock x:Name="TxtPaletteInfo" Classes="studio-hint" IsVisible="False" TextWrapping="Wrap"/>
            <WrapPanel x:Name="PaletteSwatchPanel" IsVisible="False" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>

        <Button x:Name="BtnSpritePipelineApply" Classes="primary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconCheck}" Classes="action-icon"/>
            <TextBlock Text="Applica filtri selezionati"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="ROI e composizione"/>
        <Button x:Name="BtnSpriteSelect" Classes="secondary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconCrop}" Classes="action-icon"/>
            <TextBlock Text="Seleziona area"/>
          </StackPanel>
        </Button>
        <Border Background="#090b12" BorderBrush="#1d2333" BorderThickness="1" CornerRadius="4" Padding="7">
          <TextBlock x:Name="TxtSpriteSelectionInfo"
                     Foreground="#8790b6"
                     FontSize="10"
                     FontFamily="Consolas,Monospace"
                     TextWrapping="Wrap"
                     Text="Nessuna selezione.&#x0a;Trascina sull'immagine per iniziare."/>
        </Border>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteSelectAll" Grid.Column="0" Classes="secondary" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconSelectAll}" Classes="action-icon"/>
              <TextBlock Text="Tutto"/>
            </StackPanel>
          </Button>
          <Button x:Name="BtnSpriteClearSelection" Grid.Column="2" Classes="secondary" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconX}" Classes="action-icon"/>
              <TextBlock Text="Clear"/>
            </StackPanel>
          </Button>
        </Grid>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteExportSelection" Grid.Column="0" Classes="secondary" Content="Export ROI" IsEnabled="False"/>
          <Button x:Name="BtnSpriteCrop" Grid.Column="2" Classes="secondary" Content="Ritaglia" IsEnabled="False"/>
        </Grid>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteRemove" Grid.Column="0" Classes="secondary" Content="Rimuovi" IsEnabled="False"/>
          <TextBlock Grid.Column="2" Classes="studio-hint" Text="Paste nel blocco Slicing"/>
        </Grid>
      </StackPanel>
    </Border>

    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Slicing"/>
        <CheckBox x:Name="ChkSpriteManualCrop"
                  Content="Crop manuale: trascina sul canvas"
                  ToolTip.Tip="Ritaglia subito il documento quando rilasci la selezione sul canvas."/>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteDetect" Grid.Column="0" Classes="secondary" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconTarget}" Classes="action-icon"/>
              <TextBlock Text="Rileva"/>
            </StackPanel>
          </Button>
          <Button x:Name="BtnSpriteGridSlice" Grid.Column="2" Classes="secondary" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconGrid}" Classes="action-icon"/>
              <TextBlock Text="Griglia"/>
            </StackPanel>
          </Button>
        </Grid>
        <Grid ColumnDefinitions="*,6,*">
          <StackPanel Grid.Column="0" Spacing="2">
            <TextBlock Classes="studio-hint" Text="Righe"/>
            <TextBox x:Name="TxtSpriteRows" Text="2"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="2">
            <TextBlock Classes="studio-hint" Text="Colonne"/>
            <TextBox x:Name="TxtSpriteCols" Text="2"/>
          </StackPanel>
        </Grid>
        <TextBlock x:Name="TxtSpriteCellsSummary"
                   Classes="studio-hint"
                   Text="Nessun frame rilevato."/>
        <Border Background="#090b12" BorderBrush="#1d2333" BorderThickness="1" CornerRadius="4" Padding="2">
          <ListBox x:Name="SpriteCellList"
                   Height="82"
                   Background="Transparent"
                   FontSize="10"
                   Foreground="#8f96b8"/>
        </Border>
        <Button x:Name="BtnSpriteSaveSelectedFrame"
                Classes="secondary"
                HorizontalAlignment="Stretch"
                IsEnabled="False">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconSave}" Classes="action-icon"/>
            <TextBlock Text="Esporta frame selezionato"/>
          </StackPanel>
        </Button>
        <Button x:Name="BtnSpriteExportFramesZip"
                Classes="secondary"
                HorizontalAlignment="Stretch"
                IsEnabled="False">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconSave}" Classes="action-icon"/>
            <TextBlock Text="Esporta tutti in ZIP"/>
          </StackPanel>
        </Button>
        <Button x:Name="BtnSpriteFloatingPaste" Classes="secondary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconPaste}" Classes="action-icon"/>
            <TextBlock Text="Crea atlas pulito"/>
          </StackPanel>
        </Button>
        <StackPanel x:Name="SpritePasteActiveBar" IsVisible="False" Spacing="5">
          <Grid ColumnDefinitions="*,6,*">
            <ToggleButton x:Name="BtnSpritePasteDest" Grid.Column="0" Classes="tool-toggle" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Path Data="{StaticResource IconTarget}" Classes="action-icon"/>
                <TextBlock Text="Dest"/>
              </StackPanel>
            </ToggleButton>
            <ToggleButton x:Name="BtnSpritePasteSrc" Grid.Column="2" Classes="tool-toggle" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Path Data="{StaticResource IconImage}" Classes="action-icon"/>
                <TextBlock Text="Src"/>
              </StackPanel>
            </ToggleButton>
          </Grid>
          <Button x:Name="BtnSpritePasteCopy" Classes="secondary" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconCopy}" Classes="action-icon"/>
              <TextBlock Text="Copia selezione sorgente"/>
            </StackPanel>
          </Button>
          <TextBlock x:Name="TxtSpritePasteBufferStatus" Classes="studio-hint" Text="Buffer: vuoto"/>
          <Button x:Name="BtnSpritePasteExit" Classes="secondary" Content="Esci atlas pulito" HorizontalAlignment="Stretch"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Palette e trasformazioni"/>
        <Grid ColumnDefinitions="*,6,*">
          <StackPanel Grid.Column="0" Spacing="3">
            <TextBlock Classes="studio-hint" Text="Larghezza"/>
            <TextBox x:Name="TxtSpriteResizeW" Text="64" PlaceholderText="px"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="3">
            <TextBlock Classes="studio-hint" Text="Altezza"/>
            <TextBox x:Name="TxtSpriteResizeH" Text="64" PlaceholderText="px"/>
          </StackPanel>
        </Grid>
        <Button x:Name="BtnSpriteResizeNearest" Classes="secondary" HorizontalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconCenter}" Classes="action-icon"/>
            <TextBlock Text="Ridimensiona nearest"/>
          </StackPanel>
        </Button>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteMirrorH" Grid.Column="0" Classes="secondary" Content="Mirror H"/>
          <Button x:Name="BtnSpriteMirrorV" Grid.Column="2" Classes="secondary" Content="Mirror V"/>
        </Grid>
      </StackPanel>
    </Border>

    <Border Classes="studio-section">
      <StackPanel Spacing="7">
        <TextBlock Classes="section-title" Text="Export sprite"/>
        <Grid ColumnDefinitions="*,6,*">
          <Button x:Name="BtnSpriteExportPng" Grid.Column="0" Classes="primary">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconImage}" Classes="action-icon"/>
              <TextBlock Text="PNG"/>
            </StackPanel>
          </Button>
          <Button x:Name="BtnSpriteExportJson" Grid.Column="2" Classes="secondary">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconSave}" Classes="action-icon"/>
              <TextBlock Text="JSON"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
